# Copie este arquivo para .env.docker e preencha com os dados reais do banco
# na máquina onde o Postgres está rodando. NÃO use "localhost" aqui — dentro do
# container, "localhost" é o próprio container, não a máquina do banco.
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=192.168.0.XXX
DB_PORT=5433
